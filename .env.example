# OAuth Configuration for Social Login & Registration
# Copy this file to .env and fill in your actual values

# Google OAuth Settings
# Get these from: https://console.cloud.google.com/
# Required Redirect URIs:
#   - http://localhost:5000/auth/google/callback (for login)
#   - http://localhost:5000/register/google/callback (for registration)
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Facebook OAuth Settings
# Get these from: https://developers.facebook.com/
# Required Redirect URIs:
#   - http://localhost:5000/auth/facebook/callback (for login)
#   - http://localhost:5000/register/facebook/callback (for registration)
FACEBOOK_CLIENT_ID=your_facebook_app_id_here
FACEBOOK_CLIENT_SECRET=your_facebook_app_secret_here

# Application Settings
# IMPORTANT: Use HTTPS in production
APP_BASE_URL=http://localhost:5000

# Firebase Configuration for Web and Firestore
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id_here
FIREBASE_STORAGE_BUCKET=your_project_id_here.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
FIREBASE_APP_ID=your_firebase_app_id_here
FIREBASE_MEASUREMENT_ID=your_measurement_id_here

# Secret Key (Optional - override the default in app.py)
# SECRET_KEY=your-secret-key-here

# Email Configuration (for OTP and notifications)
# For Gmail: Use App Password (not your regular password)
# Enable 2FA on Gmail, then generate App Password at: https://myaccount.google.com/apppasswords
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=danielpenalosa1313@gmail.com
MAIL_PASSWORD=shibmhsaraukuonx
MAIL_DEFAULT_SENDER=danielpenalosa1313@gmail.com
